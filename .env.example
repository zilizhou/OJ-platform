DATABASE_URL=postgresql://oj:oj@localhost:5432/oj
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change-me-in-prod
API_PORT=3001
WEB_PORT=5173
JUDGE_WORKDIR=/tmp/oj-judge

# 对外访问域名（OAuth/SSO 回调默认基于此）
OJ_PUBLIC_ORIGIN=https://oj.z-xin.net

# 知新芸 OAuth2 集成 - 在 auth.z-xin.net 管理后台注册应用后填入
ZXY_CLIENT_ID=pending
ZXY_CLIENT_SECRET=pending
ZXY_REDIRECT_URI=https://oj.z-xin.net/api/auth/oauth/zxy/callback
ZXY_AUTHORIZE_URL=https://auth.z-xin.net/oauth2/authorize
ZXY_TOKEN_URL=https://auth.z-xin.net/api/oauth2/token
ZXY_USERINFO_URL=https://auth.z-xin.net/api/oauth2/userinfo

# 知新芸 SSO（服务大厅一点即进）
ZXY_SSO_AUTH_URL=https://auth.z-xin.net/api/sso/auth
ZXY_SSO_CHECK_TICKET_URL=https://auth.z-xin.net/api/sso/checkTicket

# 知新芸服务端调 /api/integrations/* 用的 M2M API Key(空 = 关掉集成 API)
INTEGRATION_API_KEY=
